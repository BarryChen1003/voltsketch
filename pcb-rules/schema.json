{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PCB Design Rules Schema",
  "description": "PCB 設計規則資料結構定義",
  "type": "object",
  "required": ["id", "name", "category", "rules"],
  "properties": {
    "id": {
      "type": "string",
      "description": "規則集唯一識別碼"
    },
    "name": {
      "type": "string",
      "description": "規則集名稱"
    },
    "category": {
      "type": "string",
      "enum": ["clearance", "width", "via", "power", "high-speed", "analog", "manufacturing"],
      "description": "規則類別"
    },
    "description": {
      "type": "string",
      "description": "規則集描述"
    },
    "rules": {
      "type": "array",
      "description": "規則列表",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "value", "unit"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "type": {"type": "string", "enum": ["min", "max", "range"]},
          "value": {"type": "number"},
          "unit": {"type": "string", "enum": ["mm", "mil", "ohm", "pF", "nH"]},
          "description": {"type": "string"},
          "severity": {"type": "string", "enum": ["error", "warning", "info"]}
        }
      }
    },
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"}
  }
}
